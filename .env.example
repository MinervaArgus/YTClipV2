# Optional ElevenLabs key
ELEVENLABS_API_KEY=your_api_key_here

# Optional absolute ffmpeg path (Windows example)
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe

# Edge TTS voice (no API key required)
# EDGE_TTS_VOICE=en-US-AriaNeural

# Optional Ollama override for OG narration summaries
# OG_TTS_SUMMARY_MODEL=gemma3:4b
